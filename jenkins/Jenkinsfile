pipeline{
  agent any
  stages{
    stage('build'){
      steps{
        sh 'echo "Build is successful"'
      }
    }
    stage('deploy'){
      steps{
        sh 'echo "Deploy completed"'
      }
    }
    stage('run'){
      steps{
        sh '  bash  ${WORKSPACE}/linux/script.sh'
      }
    }
  }
}
